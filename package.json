{
  "name": "iata-ssim",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "description": "TypeScript parsers for IATA SSIM (Standard Schedules Information Manual) data formats. Currently implements Chapter 7 — Schedule Data Set (.ssim files). Zero dependencies; works in Node and browsers.",
  "author": "skhrvg",
  "license": "MIT",
  "homepage": "https://iata-ssim.skhr.vg/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skhrvg/iata-ssim.git"
  },
  "bugs": "https://github.com/skhrvg/iata-ssim/issues",
  "keywords": [
    "iata",
    "ssim",
    "airline",
    "schedule",
    "parser",
    "aviation"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sds": {
      "types": "./dist/sds.d.ts",
      "import": "./dist/sds.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "samples:validate": "pnpm build && node --experimental-strip-types samples-validator/validator.ts",
    "samples:validate:verbose": "pnpm build && node --experimental-strip-types samples-validator/validator.ts --verbose",
    "version:patch": "npm version patch --no-git-tag-version",
    "prepublishOnly": "pnpm build && pnpm test && pnpm lint && pnpm type-check"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^25.7.0",
    "eslint": "^10.3.0",
    "eslint-plugin-format": "^2.0.1",
    "jiti": "^2.7.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.6"
  }
}
